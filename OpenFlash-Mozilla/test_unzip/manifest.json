{
  "manifest_version": 3,
  "key": "",
  "name": "OpenFlash",
  "version": "1.0",
  "description": "Flashcards made easy. Extract from Quizlet and review offline.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "identity"
  ],
  "host_permissions": [
    "https://*.quizlet.com/*",
    "https://*.knowt.com/*",
    "https://knowt.com/*",
    "https://knowt-user-attachments.s3.amazonaws.com/*",
    "https://www.google.com/recaptcha/*",
    "https://www.gstatic.com/recaptcha/*",
    "https://firebaseappcheck.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "637353478320-pla6m2kn0lkuqgogmm19eu2dut5q7j80.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_page": "index.html",
  "background": {
    "scripts": [
      "assets/background.js-Cqf5l4LR.js"
    ],
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.js-loader-2SL0dS-s.js"
      ],
      "matches": [
        "*://*.quizlet.com/*",
        "*://quizlet.com/*",
        "*://*.knowt.com/*",
        "*://knowt.com/*"
      ],
      "css": [
        "styles/banner.css"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "openflash-app-v1@mozilla.org",
      "strict_min_version": "109.0"
    }
  },
  "web_accessible_resources": [
    {
      "matches": [
        "*://*.knowt.com/*",
        "*://*.quizlet.com/*",
        "*://knowt.com/*",
        "*://quizlet.com/*"
      ],
      "resources": [
        "assets/chunk-BNv3lrIs.js",
        "assets/content.js-G9TplW94.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
